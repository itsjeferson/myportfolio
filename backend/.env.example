# Server
PORT=5000
NODE_ENV=development

# CORS - the URL where the React client runs
CLIENT_ORIGIN=http://localhost:51765

# SMTP (used to email you contact-form submissions)
# Leave blank in development - submissions will just be logged to the console.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Where contact-form submissions should be delivered
CONTACT_EMAIL_TO=

# Rate limiting for /api/contact
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=10
